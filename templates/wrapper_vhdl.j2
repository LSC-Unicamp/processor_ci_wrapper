-- Bus type: {{ bus_type }}

library ieee;
use ieee.std_logic_1164.all;
use ieee.numeric_std.all;

{{ use_clauses }}
-- Common work library packages for Potato and similar cores
use work.pp_types.all;
use work.pp_utilities.all;

entity processorci_top is
  generic (
    CLK_FREQ            : natural := 50000000;
    BIT_RATE            : natural := 115200;
    PAYLOAD_BITS        : natural := 8;
    BUFFER_SIZE         : natural := 8;
    PULSE_CONTROL_BITS  : natural := 1;
    BUS_WIDTH           : natural := 32;
    WORD_SIZE_BY        : natural := 4;
    ID                  : natural := 0;
    RESET_CLK_CYCLES    : natural := 0;
    MEMORY_FILE         : string  := "";
    MEMORY_SIZE         : natural := 4096;
    PIPELINED_WISHBONE  : boolean := false
  );
  port (
{% if simulation %}
    sys_clk        : in  std_logic;  -- Clock de sistema
    rst_n          : in  std_logic;  -- Reset do sistema

    core_cyc       : out std_logic;  -- Indica uma transação ativa
    core_stb       : out std_logic;  -- Indica uma solicitação ativa
    core_we        : out std_logic;  -- 1 = Write, 0 = Read
    core_sel       : out std_logic_vector(3 downto 0);   -- Seletores de byte
    core_addr      : out std_logic_vector(31 downto 0);  -- Endereço
    core_data_out  : out std_logic_vector(31 downto 0);  -- Dados de entrada (para escrita)
    core_data_in   : in  std_logic_vector(31 downto 0);  -- Dados de saída (para leitura)
    core_ack       : in  std_logic   -- Confirmação da transação
{% if second_memory %}
    ;
    data_mem_cyc       : out std_logic;
    data_mem_stb       : out std_logic;
    data_mem_we        : out std_logic;
    data_mem_sel       : out std_logic_vector(3 downto 0);
    data_mem_addr      : out std_logic_vector(31 downto 0);
    data_mem_data_out  : out std_logic_vector(31 downto 0);
    data_mem_data_in   : in  std_logic_vector(31 downto 0);
    data_mem_ack       : in  std_logic
{% endif %}

{% else %}
    sys_clk   : in  std_logic;  -- Clock de sistema
    rst_n     : in  std_logic;  -- Reset do sistema

    -- UART pins
    rx        : in  std_logic;
    tx        : out std_logic;

    -- SPI pins
    sck       : in  std_logic;
    cs        : in  std_logic;
    mosi      : in  std_logic;
    miso      : out std_logic;

    -- SPI control pins
    rw        : in  std_logic;
    intr      : out std_logic
{% endif %}
  );
end entity processorci_top;

architecture rtl of processorci_top is

  {{ component_declarations }}

  signal clk_core : std_logic;
  signal rst_core : std_logic;

{% if not simulation %}
  -- Wishbone bus signals (non-simulation mode)
  signal core_cyc       : std_logic;
  signal core_stb       : std_logic;
  signal core_we        : std_logic;
  signal core_sel       : std_logic_vector(3 downto 0);
  signal core_addr      : std_logic_vector(31 downto 0);
  signal core_data_out  : std_logic_vector(31 downto 0);
  signal core_data_in   : std_logic_vector(31 downto 0);
  signal core_ack       : std_logic;

{% if second_memory %}
  signal data_mem_cyc       : std_logic;
  signal data_mem_stb       : std_logic;
  signal data_mem_we        : std_logic;
  signal data_mem_sel       : std_logic_vector(3 downto 0);
  signal data_mem_addr      : std_logic_vector(31 downto 0);
  signal data_mem_data_out  : std_logic_vector(31 downto 0);
  signal data_mem_data_in   : std_logic_vector(31 downto 0);
  signal data_mem_ack       : std_logic;
{% endif %}
{% endif %}

  signal core_data_in_mux : std_logic_vector(31 downto 0);
  signal core_ack_mux     : std_logic;

{% if second_memory %}
  signal data_mem_data_in_mux : std_logic_vector(31 downto 0);
  signal data_mem_ack_mux     : std_logic;
{% endif %}

begin

  clk_core <= sys_clk;
  rst_core <= not rst_n;

{% if not simulation %}
  u_Controller : entity work.Controller
    generic map (
      CLK_FREQ           => CLK_FREQ,
      BIT_RATE           => BIT_RATE,
      PAYLOAD_BITS       => PAYLOAD_BITS,
      BUFFER_SIZE        => BUFFER_SIZE,
      PULSE_CONTROL_BITS => PULSE_CONTROL_BITS,
      BUS_WIDTH          => BUS_WIDTH,
      WORD_SIZE_BY       => WORD_SIZE_BY,
      ID                 => ID,
      RESET_CLK_CYCLES   => RESET_CLK_CYCLES,
      MEMORY_FILE        => MEMORY_FILE,
      MEMORY_SIZE        => MEMORY_SIZE
    )
    port map (
      clk             => sys_clk,

      rst_n           => rst_n,

      -- SPI signals
      sck_i           => sck,
      cs_i            => cs,
      mosi_i          => mosi,
      miso_o          => miso,

      -- SPI callback signals
      rw_i            => rw,
      intr_o          => intr,

      -- UART signals
      rx              => rx,
      tx              => tx,

      -- Clock, reset, and bus signals
      clk_core_o      => clk_core,
      rst_core_o      => rst_core,

      -- Barramento padrão (Wishbone)
      core_cyc_i      => core_cyc,
      core_stb_i      => core_stb,
      core_we_i       => core_we,
      core_addr_i     => core_addr,
      core_data_i     => core_data_out,
      core_data_o     => core_data_in,
      core_ack_o      => core_ack
{% if second_memory %}
      ,
      data_mem_cyc_i  => data_mem_cyc,
      data_mem_stb_i  => data_mem_stb,
      data_mem_we_i   => data_mem_we,
      data_mem_addr_i => data_mem_addr,
      data_mem_data_i => data_mem_data_out,
      data_mem_data_o => data_mem_data_in,
      data_mem_ack_o  => data_mem_ack
{% endif %}
    );
{% endif %}

  p_core_pipeline : if PIPELINED_WISHBONE generate
    process (clk_core)
    begin
      if rising_edge(clk_core) then
        if rst_core = '1' then
          core_ack_mux     <= '0';
          core_data_in_mux <= (others => '0');
        else
          core_ack_mux     <= core_ack;
          core_data_in_mux <= core_data_in;
        end if;
      end if;
    end process;
  end generate;

  p_core_passthrough : if not PIPELINED_WISHBONE generate
    core_ack_mux     <= core_ack;
    core_data_in_mux <= core_data_in;
  end generate;

{% if second_memory %}
  p_data_mem_pipeline : if PIPELINED_WISHBONE generate
    process (clk_core)
    begin
      if rising_edge(clk_core) then
        if rst_core = '1' then
          data_mem_ack_mux     <= '0';
          data_mem_data_in_mux <= (others => '0');
        else
          data_mem_ack_mux     <= data_mem_ack;
          data_mem_data_in_mux <= data_mem_data_in;
        end if;
      end if;
    end process;
  end generate;

  p_data_mem_passthrough : if not PIPELINED_WISHBONE generate
    data_mem_ack_mux     <= data_mem_ack;
    data_mem_data_in_mux <= data_mem_data_in;
  end generate;
{% endif %}

  -- Core space
  {{ create_signals }}

  {{ bus_adapter }}

  {{ processor_instance }}

  -- assign mappings
  {{ signal_mappings }}

end architecture rtl;